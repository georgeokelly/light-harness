{
  "runtime": "claude",
  "mergeMode": "settings_hooks_object",
  "managedCommands": [
    "python3 \"scripts/light_harness_hook.py\" --event beforeSubmitPrompt --strict",
    "python3 \"scripts/light_harness_hook.py\" --event beforeShellExecution --strict",
    "python3 \"scripts/light_harness_hook.py\" --event afterFileEdit",
    "python3 \"scripts/light_harness_hook.py\" --event stop"
  ],
  "config": {
    "hooks": {
      "UserPromptSubmit": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"scripts/light_harness_hook.py\" --event beforeSubmitPrompt --strict"
            }
          ]
        }
      ],
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"scripts/light_harness_hook.py\" --event beforeShellExecution --strict"
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "Edit|Write",
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"scripts/light_harness_hook.py\" --event afterFileEdit"
            }
          ]
        }
      ],
      "Stop": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"scripts/light_harness_hook.py\" --event stop"
            }
          ]
        }
      ]
    }
  }
}
